# ====================
# Project-Specific Data
# ====================

# Cache folder (processed API/download data)
cache/
*.cache

# Raw satellite imagery (very large - 1.3GB+ total)
# Upload to data repository (Zenodo/OSF/Figshare) instead
data/raw/

# Processed geospatial data
# Keep small boundary files, exclude large rasters and analysis outputs
data/processed/lulc_production/
data/processed/lulc_final_v2/
data/processed/ca_ann/
data/processed/ahp/

# If you want to exclude ALL processed data, uncomment:
# data/processed/

# Generated maps (can be regenerated from code)
# Uncomment if you want to keep final publication figures in git:
# maps/

# ====================
# Large GIS/Remote Sensing Files
# ====================
*.tif
*.tiff
*.TIF
*.TIFF
*.jp2
*.JP2
*.img
*.IMG
*.hdf
*.hdf5
*.h5
*.nc
*.grib
*.grib2

# Compressed archives (download these separately)
*.zip
*.tar
*.tar.gz
*.tar.bz2
*.7z
*.rar

